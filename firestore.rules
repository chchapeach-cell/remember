rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is one of the default bootstrap admins
    function isSpecialAdmin() {
      return request.auth != null && 
        request.auth.token.email != null && 
        (request.auth.token.email == 'tamrri@gmail.com' || request.auth.token.email == 'ch.chapeach@gmail.com');
    }

    // Helper function to check if the user is an executive or staff
    function isStaffOrExecutive() {
      return request.auth != null && (
        isSpecialAdmin() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'executive' || 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff')
        )
      );
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isStaffOrExecutive());
    }

    match /tasks/{taskId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isStaffOrExecutive();
    }

    match /allowed_emails/{email} {
      // Allow any logged in user to check a single document in whitelist
      allow get: if request.auth != null;
      // List and write are strictly protected for staff/executives
      allow list: if isStaffOrExecutive();
      allow write: if isStaffOrExecutive();
    }
  }
}
